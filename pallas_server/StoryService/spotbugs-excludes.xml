<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
  <!-- Exclude generated API classes -->
  <Match>
    <Class name="~com\.pallas\.storyservice\.api\..*"/>
  </Match>
  <!-- Exclude generated model classes -->
  <Match>
    <Class name="~com\.pallas\.storyservice\.model\..*"/>
  </Match>
  <!-- Exclude all generated client code from community-service -->
  <Match>
    <Class name="~com\.pallas\.communityservice\.client\..*"/>
  </Match>
</FindBugsFilter>
