<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" packages="com.pallas.logger">
  <Filters>
    <BacktraceFilter/>
  </Filters>
  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%d %-5level %logger{36} - %msg%n"/>
    </Console>
  </Appenders>
  <Loggers>
    <Root level="all">
      <AppenderRef ref="Console"/>
    </Root>
  </Loggers>
</Configuration>
